# Frontend dev server port (Vite)
CLIENT_PORT=5173

# Backend API server port (Fastify)
SERVER_PORT=3456

# Backend bind host (default: 127.0.0.1)
SERVER_HOST=127.0.0.1

# Allowed web origins for CORS (comma-separated). Default follows CLIENT_PORT localhost origins.
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
